# Database connection. Default: local SQLite file.
# For PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/car_market
DATABASE_URL=sqlite:///data/car_market.db

# Listing source. Leave empty to run the scraper in demo mode
# (locally generated HTML pages, no external requests).
# For real auto.ru data just the host is enough — regions are configured below:
#   SCRAPER_BASE_URL=https://auto.ru
SCRAPER_BASE_URL=

# Regions to scrape (comma-separated auto.ru slugs).
# "rossiya" = one nationwide freshest-first feed (recommended);
# or per-city: moskva,sankt-peterburg,ekaterinburg,...
SCRAPER_REGIONS=rossiya

# Politeness settings for the scraper.
# Keep pages low for frequent scheduler runs: the listing is sorted
# newest-first, so 5 pages (~185 ads) per pass is enough to catch new cars.
SCRAPER_DELAY_SECONDS=1.5
SCRAPER_MAX_PAGES=5
SCRAPER_CONCURRENCY=2

# Background re-scrape interval for `python -m scraper.scheduler`, in minutes.
# 15 min = fresh deals appear within minutes of posting while staying
# well under auto.ru's anti-bot rate limits.
SCRAPE_INTERVAL_MINUTES=15

# Scheduler retrains the model automatically once this many new ads arrive
RETRAIN_MIN_NEW_ADS=50

# AI reliability check (dashboard "🔧 Проверка надёжности" + Mini App).
# FREE: get a Google Gemini key at https://aistudio.google.com/app/apikey
# (Gemini 2.0 Flash with free Google Search grounding). Leave empty to hide
# the feature. If ANTHROPIC_API_KEY is set instead, Claude + web search is used.
GEMINI_API_KEY=

# Optional proxy for the Gemini call ONLY (rest of the app stays direct).
# The Gemini free tier is geo-restricted (quota 0 in some countries); route
# just this request through an exit-node abroad. Supports http(s):// and
# socks5h:// (e.g. an `ssh -D 1080 user@vps-abroad` tunnel → socks5h://127.0.0.1:1080).
GEMINI_PROXY=

# OpenRouter — FREE, reachable from regions where Gemini's free tier is
# geo-blocked (no server/proxy needed). Get a key at https://openrouter.ai/keys
# When set, it's used for the reliability check (no live web search — the
# verdict comes from the model's knowledge). Override the model if needed.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Telegram bot (create one via @BotFather and paste the token here).
# Run with: python3 -m bot.main
TELEGRAM_BOT_TOKEN=
# How often the bot checks for fresh hot deals to push to subscribers
BOT_WATCH_INTERVAL_MINUTES=15

# Telegram Mini App: public HTTPS URL of `python3 -m bot.webapp`
# (e.g. a cloudflared/ngrok tunnel to localhost:8050). When set, the bot
# shows an "open app" button. WEBAPP_REQUIRE_AUTH=1 enforces initData checks.
WEBAPP_URL=
WEBAPP_PORT=8050
WEBAPP_REQUIRE_AUTH=0
