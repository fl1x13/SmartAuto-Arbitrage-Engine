<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.autoradar</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/antonovdi/Pet_project_fable/scripts/autoradar.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/antonovdi/Pet_project_fable</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Library/Frameworks/Python.framework/Versions/3.13/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <!-- start at login -->
    <key>RunAtLoad</key>
    <true/>

    <!-- restart the whole supervisor if it ever exits -->
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/antonovdi/Pet_project_fable/.autoradar/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/antonovdi/Pet_project_fable/.autoradar/launchd.err.log</string>
</dict>
</plist>
